# 환경변수 예시. 이 파일은 커밋되며, 실제 값은 .env.local 또는 Vercel 대시보드에 등록하세요.

# 국토교통부 실거래가 OpenAPI Decoding 키
# 발급: https://www.data.go.kr/data/15126474/openapi.do
MOLIT_API_KEY=

# 카카오 지도 JavaScript API 키
# 발급: https://developers.kakao.com → 내 애플리케이션 → 앱 키 → JavaScript 키
# 카카오 앱 설정에서 사이트 도메인 등록 필요 (localhost:3000, daerim.vercel.app 등)
NEXT_PUBLIC_KAKAO_MAP_KEY=

# (선택) Google Analytics 4 측정 ID. 형식: G-XXXXXXXXXX
# 발급: analytics.google.com → 관리 → 데이터 스트림 → 측정 ID
NEXT_PUBLIC_GA_ID=

# (선택) 구글 서치 콘솔 사이트 인증 토큰. <meta name="google-site-verification" content="..."> 의 content 값
# 발급: search.google.com/search-console → 속성 추가 → 'HTML 태그' 방식
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# (선택) 네이버 서치어드바이저 사이트 인증 토큰. <meta name="naver-site-verification" content="..."> 의 content 값
# 발급: searchadvisor.naver.com → 사이트 등록 → 'HTML 태그' 방식
NEXT_PUBLIC_NAVER_SITE_VERIFICATION=
